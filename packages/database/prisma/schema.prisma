generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// BLOG POSTS Ś AI-indexable content engine
// ============================================
model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @db.Text
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  readingTime Int      @default(0)
  views       Int      @default(0)
  tags        Tag[]    @relation("BlogPostTags")
  seoTitle    String?
  seoDesc     String?
  ogImage     String?
  category    String   @default("engineering")

  @@index([slug])
  @@index([published, publishedAt])
  @@index([category])
  @@map("blog_posts")
}

// ============================================
// PROJECTS / CASE STUDIES Ś proof of work
// ============================================
model Project {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  client       String
  clientCountry String  @default("India")
  summary      String
  problem      String   @db.Text
  solution     String   @db.Text
  result       String   @db.Text
  metrics      Json
  techStack    String[]
  category     String
  featured     Boolean  @default(false)
  published    Boolean  @default(false)
  completedAt  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  liveUrl      String?
  githubUrl    String?
  coverImage   String?
  views        Int      @default(0)
  testimonial  Testimonial?

  @@index([slug])
  @@index([featured, published])
  @@index([category])
  @@map("projects")
}

// ============================================
// TESTIMONIALS Ś social proof engine
// ============================================
model Testimonial {
  id          String   @id @default(cuid())
  clientName  String
  clientRole  String
  clientCompany String
  clientCountry String
  clientAvatar String?
  quote       String   @db.Text
  rating      Int      @default(5)
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  projectId   String?  @unique
  project     Project? @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())

  @@index([featured, published])
  @@map("testimonials")
}

// ============================================
// CONTACT LEADS Ś inbound pipeline
// ============================================
model ContactLead {
  id          String      @id @default(cuid())
  name        String
  email       String
  company     String?
  country     String?
  budget      String?
  timeline    String?
  message     String      @db.Text
  projectType String?
  status      LeadStatus  @default(NEW)
  source      String      @default("website")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  notes       String?     @db.Text
  repliedAt   DateTime?

  @@index([status, createdAt])
  @@index([email])
  @@map("contact_leads")
}

// ============================================
// PAGE VIEWS Ś analytics engine
// ============================================
model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  city      String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
  @@map("page_views")
}

// ============================================
// SKILLS Ś structured expertise data
// ============================================
model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String
  yearsExp    Int
  level       SkillLevel @default(ADVANCED)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)

  @@index([category])
  @@map("skills")
}

// ============================================
// TAGS Ś content taxonomy
// ============================================
model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  posts     BlogPost[]  @relation("BlogPostTags")

  @@map("tags")
}

// ============================================
// SITE METADATA Ś single source of truth
// ============================================
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

// ============================================
// ENUMS
// ============================================
enum LeadStatus {
  NEW
  CONTACTED
  IN_DISCUSSION
  CONVERTED
  CLOSED
  SPAM
}

enum SkillLevel {
  FAMILIAR
  PROFICIENT
  ADVANCED
  EXPERT
}

